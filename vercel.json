{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/expedisi/:id",
      "destination": "/api/expedisi?id=:id"
    },
    {
      "source": "/api/layanan/:id",
      "destination": "/api/layanan?id=:id"
    },
    {
      "source": "/api/users/:id",
      "destination": "/api/users?id=:id"
    },
    {
      "source": "/api/scans/:id",
      "destination": "/api/scans?id=:id"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
